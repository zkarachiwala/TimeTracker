@inject ITimeEntryService TimeEntryService
@inject IProjectService ProjectService
@inject ISnackbar Snackbar

<MudDrawer Open="_open" OpenChanged="HandleOpenChanged" Anchor="Anchor.Bottom"
           Variant="DrawerVariant.Temporary" Elevation="16" Class="entry-sheet"
           Style="border-radius:18px 18px 0 0; overflow:hidden;">
    @if (_open)
    {
    <div class="sheet-grip-pill"></div>

    <MudDrawerHeader Class="d-flex align-center justify-space-between pa-4">
        <MudText Typo="Typo.h6">@(IsEditing ? "Edit entry" : "New time entry")</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
    </MudDrawerHeader>

    <div style="padding:8px 20px 24px; overflow-y:auto;">
        <MudSelect T="int" Label="Project" @bind-Value="projectId" Variant="Variant.Outlined"
                   Class="mb-3" AnchorOrigin="Origin.BottomCenter">
            @foreach (var p in projects)
            {
                <MudSelectItem Value="p.Id">@p.Name</MudSelectItem>
            }
        </MudSelect>

        <MudDatePicker Label="Date" @bind-Date="date" Variant="Variant.Outlined"
                       DateFormat="yyyy-MM-dd" Class="mb-3" PickerVariant="PickerVariant.Dialog" />

        <div class="d-flex gap-3 mb-2">
            <MudTimePicker Label="Start" @bind-Time="startTime" Variant="Variant.Outlined"
                           AmPm="false" Class="flex-1" PickerVariant="PickerVariant.Dialog" />
            <MudTimePicker Label="End" @bind-Time="endTime" Variant="Variant.Outlined"
                           AmPm="false" Class="flex-1" PickerVariant="PickerVariant.Dialog" />
        </div>

        <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary)">
            Quick duration from start
        </MudText>
        <div class="d-flex flex-wrap gap-2 mb-4">
            @foreach (var mins in new[] { 15, 30, 45, 60, 90, 120 })
            {
                var label = mins < 60 ? $"{mins}m" : $"{mins / 60}h{(mins % 60 > 0 ? $" {mins % 60}m" : "")}";
                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small"
                         OnClick="() => QuickDuration(mins)">
                    @label
                </MudChip>
            }
        </div>

        <MudTextField Label="Note (optional)" @bind-Value="note" Variant="Variant.Outlined"
                      ShrinkLabel="true" Class="mb-3" />

        <MudTextField Label="Invoice reference (optional)" @bind-Value="invoiceReference"
                      Variant="Variant.Outlined" ShrinkLabel="true" Class="mb-3"
                      Placeholder="e.g. INV-0042"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Receipt" />

        <MudPaper Outlined="true" Class="d-flex align-center justify-space-between pa-3 mb-4"
                  Style="background:rgba(0,104,205,0.06); border-radius:8px; border-color:transparent">
            <MudText Typo="Typo.subtitle2" Style="color:var(--mud-palette-text-secondary)">Duration</MudText>
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="tabnum" Style="font-weight:700">
                @DurationDisplay
            </MudText>
        </MudPaper>

        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                   Size="Size.Large" Disabled="!IsValid" OnClick="Save"
                   StartIcon="@Icons.Material.Filled.Check" Class="mb-2">
            @(IsEditing ? "Save changes" : "Add entry")
        </MudButton>

        @if (IsEditing)
        {
            <MudButton FullWidth="true" Variant="Variant.Text" Class="mt-1"
                       Style="color:var(--mud-palette-error)"
                       StartIcon="@Icons.Material.Filled.DeleteOutline"
                       OnClick="Delete">
                Delete entry
            </MudButton>
        }
    </div>
    } @* end @if (_open) *@
</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public TimeEntryResponse? Entry { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private List<ProjectResponse> projects = [];
    private int projectId;
    private DateTime? date = DateTime.Today;
    private TimeSpan? startTime;
    private TimeSpan? endTime;
    private string note = string.Empty;
    private string? invoiceReference;

    private bool _open;

    protected override async Task OnParametersSetAsync()
    {
        if (Open && !_open)
        {
            _open = true;
            if (projects.Count == 0)
                projects = await ProjectService.GetAllProjects();
            ResetFromEntry();
        }
        else if (!Open && _open)
        {
            _open = false;
        }
    }

    private async Task HandleOpenChanged(bool value)
    {
        if (!value)
        {
            _open = false;
            await OpenChanged.InvokeAsync(false);
        }
    }

    private bool IsEditing => Entry?.Id > 0;

    private bool IsValid => endTime.HasValue && startTime.HasValue &&
        ComputeDuration() is TimeSpan d && d.TotalMinutes > 0;

    private string DurationDisplay
    {
        get
        {
            var d = ComputeDuration();
            if (d is null || d.Value.TotalMinutes <= 0) return "—";
            var h = (int)d.Value.TotalHours;
            var m = d.Value.Minutes;
            return $"{h}h {m}m";
        }
    }

    private TimeSpan? ComputeDuration()
    {
        if (!startTime.HasValue || !endTime.HasValue) return null;
        var diff = endTime.Value - startTime.Value;
        if (diff.TotalMinutes <= 0) diff = diff.Add(TimeSpan.FromHours(24));
        return diff;
    }

    // Projects loaded lazily on first open to avoid concurrent DbContext usage

    private void ResetFromEntry()
    {
        if (Entry is not null && Entry.Id > 0)
        {
            projectId = Entry.Project.Id;
            date = Entry.Start.Date;
            startTime = Entry.Start.TimeOfDay;
            endTime = Entry.End?.TimeOfDay;
            note = Entry.Note ?? string.Empty;
            invoiceReference = Entry.InvoiceReference;
        }
        else
        {
            projectId = projects.FirstOrDefault()?.Id ?? 0;
            date = DateTime.Today;
            startTime = null;
            endTime = null;
            note = string.Empty;
            invoiceReference = null;
        }
    }

    private void QuickDuration(int minutes)
    {
        if (!startTime.HasValue) startTime = TimeSpan.FromHours(DateTime.Now.Hour).Add(TimeSpan.FromMinutes(DateTime.Now.Minute));
        endTime = startTime.Value.Add(TimeSpan.FromMinutes(minutes));
    }

    private async Task Save()
    {
        var baseDate = date ?? DateTime.Today;
        var start = baseDate.Add(startTime!.Value);
        var end = baseDate.Add(endTime!.Value);
        if (end <= start) end = end.AddDays(1);

        if (IsEditing)
        {
            await TimeEntryService.UpdateTimeEntry(Entry!.Id, new TimeEntryUpdateRequest
            {
                ProjectId = projectId,
                Start = start,
                End = end,
                Note = note,
                InvoiceReference = string.IsNullOrWhiteSpace(invoiceReference) ? null : invoiceReference.Trim(),
                InvoicedAt = string.IsNullOrWhiteSpace(invoiceReference) ? null : (Entry.InvoicedAt ?? DateTime.Now)
            });
            Snackbar.Add("Entry updated", Severity.Success);
        }
        else
        {
            await TimeEntryService.CreateTimeEntry(new TimeEntryCreateRequest
            {
                ProjectId = projectId,
                Start = start,
                End = end,
                Note = note
            });
            Snackbar.Add("Entry added", Severity.Success);
        }

        await Close();
        await OnSaved.InvokeAsync();
    }

    private async Task Delete()
    {
        if (!IsEditing) return;
        await TimeEntryService.DeleteTimeEntry(Entry!.Id);
        Snackbar.Add("Entry deleted", Severity.Info);
        await Close();
        await OnSaved.InvokeAsync();
    }

    private async Task Close()
    {
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }
}
