@using TimeTracker.Web.Shared

<MudCard Class="mb-3" Style="cursor:pointer" @onclick="() => OnOpen.InvokeAsync(Project.Id)">
    <MudCardContent Style="padding:16px">
        <div class="d-flex align-start gap-3">
            <MudAvatar Class="avatar-sq"
                       Style="@($"background:{ProjectColors.ForProject(Project.Id)}22; color:{ProjectColors.ForProject(Project.Id)}; font-weight:700")">
                @Initials
            </MudAvatar>
            <div class="flex-1" style="min-width:0">
                <MudText Typo="Typo.body1" Style="font-weight:500; line-height:1.3">@Project.Name</MudText>
                <div class="d-flex align-center gap-2 mt-1 flex-wrap">
                    <MudText Typo="Typo.caption">@(Project.ClientName ?? "No client")</MudText>
                    @if (Project.HourlyRate is > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Class="rate-chip-cyan" Style="height:22px; font-size:.75rem">
                            $@Project.HourlyRate/h
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="height:22px; font-size:.75rem">
                            internal
                        </MudChip>
                    }
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick:stopPropagation="true"
                           OnClick="() => OnEdit.InvokeAsync(Project)" />
        </div>
        <div class="d-flex justify-space-between align-center mt-3">
            <MudText Typo="Typo.caption">@YtdHours h logged YTD</MudText>
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-disabled)">
                since @(Project.StartDate?.ToString("MMM yyyy") ?? "—")
            </MudText>
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public ProjectResponse Project { get; set; } = null!;
    [Parameter] public int YtdHours { get; set; }
    [Parameter] public EventCallback<int> OnOpen { get; set; }
    [Parameter] public EventCallback<ProjectResponse> OnEdit { get; set; }

    private string Initials => (Project.ClientName ?? Project.Name).Length >= 2
        ? (Project.ClientName ?? Project.Name)[..2].ToUpper()
        : (Project.ClientName ?? Project.Name).ToUpper();
}
