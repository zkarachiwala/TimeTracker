@page "/login"
@layout LoginLayout
@inject SignInManager<TimeTracker.Shared.Entities.User> SignInManager

<PageTitle>Sign in — TimeTracker</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh; align-items:center;">
    <MudItem xs="12" sm="8" md="5" lg="4" Style="max-width:400px; width:100%">
        <div class="d-flex flex-column align-center mb-6">
            <img src="/images/dzk-logo.png" alt="DZK Consulting"
                 style="height:92px; object-fit:contain; margin-bottom:10px;" />
            <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight:500">TimeTracker</MudText>
            <MudText Typo="Typo.body2" Class="mt-1" Style="color:var(--mud-palette-text-secondary)">
                Timesheets for DZK Consulting engagements.
            </MudText>
        </div>

        <MudCard Elevation="4">
            <MudCardContent Class="pa-6">
                <MudText Typo="Typo.overline">Sign in</MudText>
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)" Class="mb-4">
                    Use your DZK Google Workspace account.
                </MudText>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
                }

                @foreach (var provider in externalProviders)
                {
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large"
                               Href="@($"/auth/challenge?provider={Uri.EscapeDataString(provider.Name)}&returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}")"
                               Style="text-transform:none; font-size:.95rem; justify-content:center; gap:12px; margin-bottom:8px;">
                        <svg width="20" height="20" viewBox="0 0 48 48" style="display:inline-block">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                        </svg>
                        Sign in with @provider.DisplayName
                    </MudButton>
                }

                <MudDivider Class="my-4" />
                <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Default"
                           Href="@($"/auth/challenge?provider=Email&returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}")"
                           Style="text-transform:none">
                    <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Small" Class="mr-2" />
                    Continue with email
                </MudButton>
            </MudCardContent>
        </MudCard>

        <MudText Typo="Typo.caption" Class="d-flex justify-center mt-5"
                 Style="color:var(--mud-palette-text-secondary)">
            © 2026 DZK Consulting
        </MudText>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private IEnumerable<AuthenticationScheme> externalProviders = [];
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        externalProviders = await SignInManager.GetExternalAuthenticationSchemesAsync();

        errorMessage = Error switch
        {
            "external-login-failed" => "Sign-in failed. Please try again.",
            "no-email"              => "Your account did not provide an email address.",
            "create-user-failed"    => "Could not create a local account. Please contact the administrator.",
            "link-provider-failed"  => "Could not link your account. Please contact the administrator.",
            _                       => null
        };
    }
}
