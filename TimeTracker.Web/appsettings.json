{
  "ConnectionStrings": {
    "TimeTrackerConnection": "Server=localhost;Database=TimeTrackerDb;Encrypt=True",
    "IdentityConnection": "Server=localhost;Database=TimeTrackerDb;Encrypt=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "timetracker.dzk.com.au;timetracker-zak.azurewebsites.net",
  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "WindowMinutes": 1
    },
    "Write": {
      "PermitLimit": 60,
      "WindowMinutes": 1
    },
    "AllEntries": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    },
    "Auth": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    },
    "AuthStatus": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    }
  }
}

