{
  "ConnectionStrings": {
    "TimeTrackerConnection": "Server=localhost,1435;Database=TimeTrackerDb;TrustServerCertificate=true",
    "IdentityConnection": "Server=localhost,1435;Database=TimeTrackerDb;TrustServerCertificate=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Global": {
      "PermitLimit": 10000
    },
    "AllEntries": {
      "PermitLimit": 10000
    },
    "AuthStatus": {
      "PermitLimit": 200
    }
  }
}
