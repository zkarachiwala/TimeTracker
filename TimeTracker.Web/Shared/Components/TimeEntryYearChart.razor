@using System.Globalization
@rendermode InteractiveServer

<RadzenChart>
    <RadzenLineSeries Data="@chartData" CategoryProperty="Month" Title="@Year.ToString()"
        LineType="LineType.Solid" ValueProperty="TotalMinutes">
        <RadzenMarkers MarkerType="MarkerType.Square" />
        <RadzenSeriesDataLabels />
    </RadzenLineSeries>
    <RadzenValueAxis Formatter="@FormatAsHoursMinutes">
        <RadzenGridLines Visible="true" />
        <RadzenAxisTitle Text="Total Duration" />
    </RadzenValueAxis>
</RadzenChart>

@code {
    [Parameter] public List<TimeEntryResponse> Entries { get; set; } = new();
    [Parameter] public int Year { get; set; } = DateTime.Now.Year;

    private List<ChartPoint> chartData = new();

    protected override void OnParametersSet()
    {
        chartData = Entries
            .GroupBy(te => te.Start.Month)
            .Select(g => new ChartPoint
            {
                Month = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(g.Key),
                TotalMinutes = g.Sum(t => (t.End?.Subtract(t.Start))?.TotalMinutes ?? 0)
            })
            .OrderBy(y => DateTime.ParseExact(y.Month, "MMMM", CultureInfo.CurrentCulture).Month)
            .ToList();
    }

    private string FormatAsHoursMinutes(object value)
    {
        var total = (int)(double)value;
        return $"{total / 60}h {total % 60}m";
    }

    private class ChartPoint
    {
        public double TotalMinutes { get; set; }
        public required string Month { get; set; }
    }
}
