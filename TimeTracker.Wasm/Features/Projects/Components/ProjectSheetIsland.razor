@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject IProjectService ProjectService
@inject NavigationManager Nav
@using TimeTracker.Wasm.Shared.Theme

<MudThemeProvider Theme="@DzkTheme.Instance" />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="tt-fab">
    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
            OnClick="OpenNewSheet" />
</div>

@if (sheetOpen)
{
    <ProjectSheet @bind-Open="sheetOpen" Project="editProject" OnSaved="AfterSave" />
}

@code {
    [SupplyParameterFromQuery(Name = "edit")] public int? EditId { get; set; }

    private bool sheetOpen;
    private ProjectResponse? editProject;

    protected override async Task OnParametersSetAsync()
    {
        if (EditId.HasValue && EditId > 0)
        {
            editProject = await ProjectService.GetProjectById(EditId.Value);
            sheetOpen = editProject is not null;
        }
    }

    private void OpenNewSheet()
    {
        editProject = null;
        sheetOpen = true;
    }

    private void AfterSave() => Nav.NavigateTo(Nav.Uri.Split('?')[0], forceLoad: true);
}
