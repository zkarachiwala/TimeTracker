@inject NavigationManager Nav
@inject IServiceProvider Services
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Timer">Timer</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="entries"
                        Icon="@Icons.Material.Filled.AccessTime">Entries</MudNavLink>
            <MudNavLink Href="reports"
                        Icon="@Icons.Material.Filled.BarChart">Reports</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <MudNavLink Href="projects"
                    Icon="@Icons.Material.Filled.FolderOpen">Projects</MudNavLink>
        <MudNavLink Href="clients"
                    Icon="@Icons.Material.Filled.Business">Clients</MudNavLink>
        <MudNavLink Href="trash"
                    Icon="@Icons.Material.Filled.DeleteForever">Trash</MudNavLink>
    </AuthorizeView>

    @if (_isDevelopment)
    {
        <AuthorizeView Roles="Admin">
            <MudNavLink Href="dev"
                        Icon="@Icons.Material.Filled.DeveloperMode">Dev Tools</MudNavLink>
        </AuthorizeView>
    }
</MudNavMenu>

@code {
    private bool _isDevelopment;

    protected override void OnInitialized()
    {
        if (Services.GetService<IWebAssemblyHostEnvironment>() is { } env)
            _isDevelopment = env.Environment == "Development";
    }
}
