@page "/access-denied"
@layout LoginLayout

<PageTitle>Access Denied — TimeTracker</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh; align-items:center;">
    <MudItem xs="12" sm="8" md="5" lg="4" Style="max-width:400px; width:100%">
        <div class="d-flex flex-column align-center mb-6">
            <img src="images/dzk-logo.png" alt="DZK Consulting"
                 style="height:92px; object-fit:contain; margin-bottom:10px;" />
            <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight:500">TimeTracker</MudText>
        </div>

        <MudCard Elevation="4">
            <MudCardContent Class="pa-6 d-flex flex-column align-center" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.Block"
                         Style="font-size:3rem; color:var(--mud-palette-error); margin-bottom:16px" />
                <MudText Typo="Typo.h6" Class="mb-2">Access denied</MudText>
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)" Class="mb-4">
                    Your Google account is not authorised to use TimeTracker.
                    Contact your administrator if you believe this is an error.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="login"
                           data-enhance-nav="false">
                    Back to sign in
                </MudButton>
            </MudCardContent>
        </MudCard>

        <MudText Typo="Typo.caption" Class="d-flex justify-center mt-5"
                 Style="color:var(--mud-palette-text-secondary)">
            © 2026 DZK Consulting
        </MudText>
    </MudItem>
</MudGrid>
