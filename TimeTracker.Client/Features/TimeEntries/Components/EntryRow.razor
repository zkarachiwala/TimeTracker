@using TimeTracker.Wasm.Shared

<div class="d-flex align-center py-2 px-1" style="cursor:pointer; gap:12px;" @onclick="() => OnEdit.InvokeAsync(Entry)">
    <span class="project-dot" style="background:@ProjectColors.ForProject(Entry.Project.Id)"></span>
    <div class="flex-1" style="min-width:0">
        <MudText Typo="Typo.body2" Style="font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">
            @(ShowProject ? Entry.Project.Name : (string.IsNullOrEmpty(Entry.Note) ? "Time entry" : Entry.Note))
        </MudText>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary)">
            @if (ShowProject && !string.IsNullOrEmpty(Entry.Note)) { <span>@Entry.Note · </span> }
            @FormatTime(Entry.Start) – @(Entry.End.HasValue ? FormatTime(Entry.End.Value) : "now")
        </MudText>
    </div>
    <MudText Typo="Typo.body2" Style="font-weight:500; font-variant-numeric:tabular-nums">
        @FormatDuration(Entry.Start, Entry.End)
    </MudText>
    @if (!string.IsNullOrEmpty(Entry.InvoiceReference))
    {
        <MudTooltip Text="@($"Invoiced: {Entry.InvoiceReference}")">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small"
                     Style="color:var(--mud-palette-success)" />
        </MudTooltip>
    }
    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color:var(--mud-palette-text-disabled)" Size="Size.Small" />
</div>

@code {
    [Parameter, EditorRequired] public TimeEntryResponse Entry { get; set; } = null!;
    [Parameter] public bool ShowProject { get; set; } = true;
    [Parameter] public EventCallback<TimeEntryResponse> OnEdit { get; set; }

    private static string FormatTime(DateTime dt) => dt.ToString("h:mm tt");

    private static string FormatDuration(DateTime start, DateTime? end)
    {
        var duration = (end ?? DateTime.Now) - start;
        var h = (int)duration.TotalHours;
        var m = duration.Minutes;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }
}
