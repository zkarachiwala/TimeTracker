@inject IProjectService ProjectService
@inject IClientService ClientService
@inject ISnackbar Snackbar

<MudDrawer Open="_open" OpenChanged="HandleOpenChanged" Anchor="Anchor.Bottom"
           Variant="DrawerVariant.Temporary" Elevation="16" Class="entry-sheet"
           Style="border-radius:18px 18px 0 0; overflow:hidden;">
    @if (_open)
    {
    <div class="sheet-grip-pill"></div>

    <MudDrawerHeader Class="d-flex align-center justify-space-between pa-4">
        <MudText Typo="Typo.h6">@(IsEditing ? "Edit project" : "New project")</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" />
    </MudDrawerHeader>

    <div style="padding:16px 20px 24px; overflow-y:auto;">
        <MudTextField Label="Project name" @bind-Value="name" Variant="Variant.Outlined" Class="mb-3" />

        <MudSelect T="int?" Label="Client" @bind-Value="clientId" Variant="Variant.Outlined"
                   Class="mb-1" AnchorOrigin="Origin.BottomCenter"
                   @bind-Value:after="OnClientChanged">
            <MudSelectItem T="int?" Value="null">— No client —</MudSelectItem>
            @foreach (var c in clients.Where(c => !c.IsArchived || c.Id == clientId))
            {
                <MudSelectItem T="int?" Value="(int?)c.Id">
                    @c.Name@(c.DefaultHourlyRate.HasValue ? $" · ${c.DefaultHourlyRate}/h" : " · no default rate")@(c.IsArchived ? " (archived)" : "")
                </MudSelectItem>
            }
        </MudSelect>

        @* ── Billing toggle ── *@
        <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary)">Billing</MudText>
        <div class="d-flex gap-2 mb-3">
            <MudChip T="string" Color="@(billable ? Color.Primary : Color.Default)"
                     Variant="@(billable ? Variant.Filled : Variant.Outlined)"
                     OnClick="() => SetBillable(true)">Billable</MudChip>
            <MudChip T="string" Color="@(!billable ? Color.Primary : Color.Default)"
                     Variant="@(!billable ? Variant.Filled : Variant.Outlined)"
                     OnClick="() => SetBillable(false)">Internal</MudChip>
        </div>

        @if (billable)
        {
            var helpText = RateHelpText;
            <MudNumericField T="decimal?" Label="Hourly rate (AUD)" @bind-Value="hourlyRate"
                             Variant="Variant.Outlined" Class="mb-3" Min="0"
                             HelperText="@helpText"
                             @bind-Value:after="() => rateTouched = true" />
        }

        <MudTextField Label="Description (optional)" @bind-Value="description"
                      Variant="Variant.Outlined" Class="mb-4" />

        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                   Size="Size.Large" Disabled="!IsValid" OnClick="Save"
                   StartIcon="@Icons.Material.Filled.Check" Class="mb-2">
            @(IsEditing ? "Save changes" : "Create project")
        </MudButton>

        @if (IsEditing)
        {
            @if (_confirmingArchive)
            {
                <MudDatePicker Label="End date" @bind-Date="_archiveDate" Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" Class="mt-2 mb-2" PickerVariant="PickerVariant.Dialog" />
                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Archive"
                               Disabled="_archiveDate is null"
                               OnClick="ToggleArchive">
                        Confirm archive
                    </MudButton>
                    <MudButton Variant="Variant.Text" OnClick="() => _confirmingArchive = false">
                        Cancel
                    </MudButton>
                </div>
            }
            else
            {
                <MudButton FullWidth="true" Variant="Variant.Text" Class="mt-1"
                           Style="@(IsArchived ? "color:var(--mud-palette-text-secondary)" : "color:var(--mud-palette-warning-darken)")"
                           StartIcon="@(IsArchived ? Icons.Material.Filled.Unarchive : Icons.Material.Filled.Archive)"
                           OnClick="@(IsArchived ? (Func<Task>)ToggleArchive : BeginArchive)">
                    @(IsArchived ? "Unarchive project" : "Archive project")
                </MudButton>
            }
        }
    </div>
    } @* end @if (_open) *@
</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public ProjectResponse? Project { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private List<ClientResponse> clients = [];
    private string name = string.Empty;
    private int? clientId;
    private bool billable = true;
    private decimal? hourlyRate;
    private bool rateTouched;
    private string description = string.Empty;

    private bool _open;
    private bool _confirmingArchive;
    private DateTime? _archiveDate;

    protected override async Task OnParametersSetAsync()
    {
        if (Open && !_open)
        {
            _open = true;
            if (clients.Count == 0)
                clients = await ClientService.GetAllClients(includeArchived: true);
            Reset();
        }
        else if (!Open && _open)
        {
            _open = false;
        }
    }

    private async Task HandleOpenChanged(bool value)
    {
        if (!value)
        {
            _open = false;
            await OpenChanged.InvokeAsync(false);
        }
    }

    private bool IsEditing => Project?.Id > 0;
    private bool IsArchived => Project?.EndDate.HasValue == true;
    private bool IsValid => !string.IsNullOrWhiteSpace(name);

    private string? RateHelpText
    {
        get
        {
            if (!clientId.HasValue) return null;
            var c = clients.FirstOrDefault(x => x.Id == clientId.Value);
            if (c?.DefaultHourlyRate.HasValue == true && hourlyRate == c.DefaultHourlyRate)
                return $"Default rate for {c.Name}";
            return "Overrides client default";
        }
    }

    private void Reset()
    {
        if (Project is not null && Project.Id > 0)
        {
            name = Project.Name;
            clientId = Project.ClientId;
            billable = Project.HourlyRate is > 0;
            hourlyRate = billable ? Project.HourlyRate : null;
            description = Project.Description ?? string.Empty;
        }
        else
        {
            name = string.Empty;
            clientId = null;
            billable = true;
            hourlyRate = null;
            description = string.Empty;
        }
        rateTouched = false;
        _confirmingArchive = false;
        _archiveDate = null;
    }

    private void OnClientChanged()
    {
        if (!rateTouched && clientId.HasValue)
        {
            var c = clients.FirstOrDefault(x => x.Id == clientId.Value);
            if (c?.DefaultHourlyRate.HasValue == true)
            {
                billable = true;
                hourlyRate = c.DefaultHourlyRate;
            }
            else
            {
                billable = false;
                hourlyRate = null;
            }
        }
    }

    private void SetBillable(bool value)
    {
        billable = value;
        rateTouched = true;
        if (!billable) hourlyRate = null;
    }

    private async Task Save()
    {
        var rate = billable ? (hourlyRate ?? 0) : 0;
        if (IsEditing)
        {
            await ProjectService.UpdateProject(Project!.Id, new ProjectUpdateRequest
            {
                Name = name,
                ClientId = clientId,
                HourlyRate = rate,
                Description = description,
                StartDate = Project.StartDate,
                EndDate = Project.EndDate
            });
            Snackbar.Add("Project updated", Severity.Success);
        }
        else
        {
            await ProjectService.CreateProject(new ProjectCreateRequest
            {
                Name = name,
                ClientId = clientId,
                HourlyRate = rate,
                Description = description,
                StartDate = DateTime.Today
            });
            Snackbar.Add("Project created", Severity.Success);
        }
        await Close();
        await OnSaved.InvokeAsync();
    }

    private Task BeginArchive()
    {
        _archiveDate = DateTime.Today;
        _confirmingArchive = true;
        return Task.CompletedTask;
    }

    private async Task ToggleArchive()
    {
        if (!IsEditing) return;
        var newEndDate = IsArchived ? null : _archiveDate;
        await ProjectService.UpdateProject(Project!.Id, new ProjectUpdateRequest
        {
            Name = Project.Name,
            ClientId = Project.ClientId,
            HourlyRate = Project.HourlyRate ?? 0,
            Description = Project.Description,
            StartDate = Project.StartDate,
            EndDate = newEndDate
        });
        Snackbar.Add(IsArchived ? "Project unarchived" : "Project archived", Severity.Success);
        await Close();
        await OnSaved.InvokeAsync();
    }

    private async Task Close()
    {
        Open = false;
        await OpenChanged.InvokeAsync(false);
    }
}
