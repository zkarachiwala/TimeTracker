@page "/login"
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="lg:px-32">
    <h3>Login</h3>
    <EditForm method="post" Model="Model" OnValidSubmit="HandleSubmit" FormName="login">
        <DataAnnotationsValidator />
        <div>
            <label for="username" class="block text-xs font-medium text-gray-700 mt-2">Username</label>
            <InputText id="username" @bind-Value="Model!.UserName"
                class="mt-1 p-2 w-full rounded-md border-gray-200 shadow-sm sm:text-sm" />
            <ValidationMessage For="() => Model!.UserName" class="text-xs text-red-600 font-bold my-1" />
        </div>
        <div>
            <label for="password" class="block text-xs font-medium text-gray-700 mt-2">Password</label>
            <InputText id="password" @bind-Value="Model!.Password" type="password"
                class="mt-1 p-2 w-full rounded-md border-gray-200 shadow-sm sm:text-sm" />
            <ValidationMessage For="() => Model!.Password" class="text-xs text-red-600 font-bold my-1" />
        </div>
        <button type="submit"
            class="block rounded-md bg-teal-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-teal-700 mt-2">
            Login
        </button>
    </EditForm>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <span class="text-xs text-red-600 font-bold my-1">@errorMessage</span>
    }
</div>

@code {
    [SupplyParameterFromForm]
    public LoginFormModel? Model { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string? errorMessage;

    protected override void OnInitialized() => Model ??= new();

    private async Task HandleSubmit()
    {
        errorMessage = null;
        var (succeeded, error) = await AuthService.LoginAsync(Model!.UserName, Model.Password);
        if (succeeded)
            NavigationManager.NavigateTo(ReturnUrl ?? "/timeentries");
        else
            errorMessage = error ?? "An unexpected error occurred.";
    }

    public class LoginFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string UserName { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }
}
