<select class="my-2 p-2 rounded-md border-gray-200 shadow-sm sm:text-sm" value="@SelectedProjectId" @onchange="HandleChange">
    <option value="0">All Projects</option>
    @foreach (var project in Projects)
    {
        <option value="@project.Id">@project.Name</option>
    }
</select>

@code {
    [Parameter] public List<ProjectResponse> Projects { get; set; } = new();
    [Parameter] public int SelectedProjectId { get; set; }
    [Parameter] public EventCallback<int> OnProjectSelected { get; set; }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            await OnProjectSelected.InvokeAsync(id);
    }
}
