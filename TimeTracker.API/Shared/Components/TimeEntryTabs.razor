<div class="hidden sm:block mt-4">
    <nav class="flex gap-6" aria-label="Tabs">
        <a @onclick="() => ChangeTab(FilterType.Day)" class="@TabCss(FilterType.Day)">By Day</a>
        <a @onclick="() => ChangeTab(FilterType.Month)" class="@TabCss(FilterType.Month)">By Month</a>
        <a @onclick="() => ChangeTab(FilterType.Year)" class="@TabCss(FilterType.Year)">By Year</a>
        <a @onclick="() => ChangeTab(FilterType.Project)" class="@TabCss(FilterType.Project)">By Project</a>
    </nav>
</div>

@code {
    [Parameter] public FilterType Current { get; set; } = FilterType.Day;
    [Parameter] public EventCallback<FilterType> OnTabChanged { get; set; }

    private async Task ChangeTab(FilterType type) => await OnTabChanged.InvokeAsync(type);

    private string TabCss(FilterType type) => type == Current
        ? "cursor-pointer shrink-0 rounded-lg bg-gray-100 p-2 text-sm font-medium text-gray-700"
        : "cursor-pointer shrink-0 rounded-lg p-2 text-sm font-medium text-gray-500 hover:bg-gray-50 hover:text-gray-700";

    public enum FilterType { Day, Month, Year, Project }
}
